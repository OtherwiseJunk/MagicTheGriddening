FROM node:24-alpine AS base
RUN apk add --no-cache libc6-compat openssl

FROM base AS deps
WORKDIR /app

# Copy workspace manifests so npm understands the workspace structure
COPY package.json package-lock.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/
COPY apps/seeder/package.json ./apps/seeder/
COPY apps/bsky-bot/package.json ./apps/bsky-bot/

RUN npm ci -w apps/web

FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

WORKDIR /app/apps/web
RUN npx prisma generate
RUN npm run build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# standalone mirrors the monorepo root — server.js is at apps/web/server.js
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/prisma ./apps/web/prisma

RUN mkdir -p /app/data && chown nextjs:nodejs /app/data

USER nextjs

EXPOSE 3000

ENV NEXT_SHARP_PATH=/app/node_modules/sharp
ENV DATABASE_URL=postgresql://postgres:postgres@postgres:5432/griddening?schema=public
ENV PORT=3000
ENV TZ=America/New_York
ENV AUTOCOMPLETE_DATA_DIR=/app/data
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
